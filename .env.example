# Google Maps Platform（前端專用）
# 用途：招生熱點圖切換為 Google Maps JavaScript 地圖
# 注意：VITE_ 變數會暴露在瀏覽器端，請使用「前端專用」API key
# 並在 Google Cloud Console 設定 HTTP referrer 限制
# 例如：
#   http://localhost:5173/*
#   http://127.0.0.1:5173/*
#   https://your-domain.example.com/*
VITE_GOOGLE_MAPS_API_KEY=

# 若未設定，招生熱點圖會維持 Leaflet + OpenStreetMap fallback
# VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
# VITE_MAP_ATTRIBUTION=&copy; OpenStreetMap contributors

# 教師端 LINE Bot 加好友連結（從 LINE Official Account Manager
# > 主頁網址 / 加入好友連結 複製，格式通常為 https://lin.ee/xxx 或
# https://line.me/R/ti/p/@xxx）
# 設定後，教師端「個人資料 > LINE Bot 綁定」會自動顯示 QR code 與加好友按鈕
VITE_LINE_BOT_FRIEND_URL=https://line.me/R/ti/p/@116fakhu 
